-- Carrega o arquivo de ícones do Rayfield (mesmo formato)
local LucideIcons = nil
task.spawn(function()
    pcall(function()
        local src = game:HttpGet("https://raw.githubusercontent.com/SiriusSoftwareLtd/Rayfield/refs/heads/main/icons.lua")
        if src and #src > 0 then
            LucideIcons = loadstring(src)()
        end
    end)
end)

local function getLucideAsset(name)
    if not LucideIcons then return nil end
    name = tostring(name):lower():match("^%s*(.-)%s*$")
    local sized = LucideIcons["48px"]
    if not sized then return nil end
    local r = sized[name]
    if not r then return nil end
    local rirs = r[2]; local riro = r[3]
    if type(r[1]) ~= "number" or type(rirs) ~= "table" or type(riro) ~= "table" then return nil end
    return {
        id             = r[1],
        imageRectSize  = Vector2.new(rirs[1], rirs[2]),
        imageRectOffset= Vector2.new(riro[1], riro[2]),
    }
end

-- Aplica ícone num ImageLabel/ImageButton (suporta Lucide name, assetid, ou número)
local function applyIcon(imgObj, raw)
    if not raw or raw == "" or raw == 0 then return end
    local s = tostring(raw)

    -- AssetId numérico ou string rbxassetid:// — aplica direto
    if s:match("^%d+$") then
        imgObj.Image   = "rbxassetid://" .. s
        imgObj.Visible = true
        return
    end
    if s:lower():find("^rbxassetid://") then
        imgObj.Image   = s
        imgObj.Visible = true
        return
    end

    -- Nome Lucide — começa invisível e aparece quando carregar
    imgObj.Visible = false
    local tries = 0
    local function tryApply()
        -- Para se o elemento foi destruído (ex: notificação sumiu)
        if not imgObj or not imgObj.Parent then return end
        local asset = getLucideAsset(s)
        if asset then
            imgObj.Image           = "rbxassetid://" .. asset.id
            imgObj.ImageRectSize   = asset.imageRectSize
            imgObj.ImageRectOffset = asset.imageRectOffset
            imgObj.Visible         = true
        elseif tries < 40 then
            tries = tries + 1
            task.delay(0.15, tryApply)
        end
    end
    tryApply()
end

local function resolveIcon(raw)
    if not raw or raw == "" then return nil end
    local s = tostring(raw)
    if s:lower():find("rbxassetid://") then return s end
    if s:match("^%d+$")               then return "rbxassetid://" .. s end
    return s  -- nome Lucide — tratado via applyIcon
end

