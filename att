            local obj = {}
            function obj:Get() return tb.Text end
            function obj:Set(v) tb.Text = v end
            table.insert(self._elements, {label=lbl:lower(), frame=outer})
            return obj
        end

        -- ────────────────────────────────────────
        --  LABEL
        -- ────────────────────────────────────────
