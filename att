function NexusUI:Notify(config)
    local cfg      = config or {}
    local title    = cfg.Title    or "Notificação"
    local message  = cfg.Message  or ""
    local duration = cfg.Duration or 4
    local ntype    = cfg.Type     or "Info"
    local iconRaw  = cfg.Icon or nil
    -- Usa o tema do cfg se passado, senão usa o tema ativo da janela
    local T        = Themes[cfg.Theme or NexusUI._activeTheme] or Themes.Dark

    local typeColor = { Info=T.Info, Success=T.Success, Warning=T.Warning, Error=T.Error }
    local accent    = typeColor[ntype] or T.Info

    -- Container raiz (sem AutomaticSize, sem clip — só posicionamento)
    local notifOuter = Instance.new("Frame")
    notifOuter.BackgroundTransparency = 1
    notifOuter.BorderSizePixel        = 0
    notifOuter.Size                   = UDim2.new(1, 0, 0, 0)  -- altura definida depois
    notifOuter.Parent                 = NotifContainer
    do
        local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 8); c.Parent = notifOuter
    end
    do
        local s = Instance.new("UIStroke")
        s.Color = T.Border; s.Thickness = 1
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        s.Parent = notifOuter
    end

    -- Inner: fundo + clip (altura também definida depois, igual ao outer)
    local notifInner = Instance.new("Frame")
    notifInner.BackgroundColor3 = T.TitleBg
    notifInner.BorderSizePixel  = 0
    notifInner.Size             = UDim2.new(1, 0, 1, 0)
    notifInner.ClipsDescendants = true
    notifInner.Parent           = notifOuter
    do
        local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 8); c.Parent = notifInner
    end

    -- Conteúdo (sem barra lateral)
    local content = Instance.new("Frame")
    content.BackgroundTransparency = 1
    content.BorderSizePixel        = 0
    content.Position               = UDim2.new(0, 0, 0, 0)
    content.Size                   = UDim2.new(1, 0, 0, 0)
    content.AutomaticSize          = Enum.AutomaticSize.Y
    content.Parent                 = notifInner
    AddPadding(content, 10, 8, 14, 14)

    local lay = Instance.new("UIListLayout")
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    lay.Padding   = UDim.new(0, 4)
    lay.Parent    = content

    -- Linha do título
    local titleRow = Instance.new("Frame")
    titleRow.BackgroundTransparency = 1
    titleRow.BorderSizePixel        = 0
    titleRow.Size                   = UDim2.new(1, 0, 0, 16)
    titleRow.LayoutOrder            = 1
    titleRow.Parent                 = content

    local titleOffX = 0
    if iconRaw then
        local img = Instance.new("ImageLabel")
        img.BackgroundTransparency = 1
        img.Size      = UDim2.new(0, 14, 0, 14)
        img.Position  = UDim2.new(0, 0, 0.5, -7)
        img.ImageColor3 = T.Text
        img.ScaleType = Enum.ScaleType.Fit
        img.Parent    = titleRow
        applyIcon(img, iconRaw)
        titleOffX = 20
    end

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Size           = UDim2.new(1, -titleOffX, 1, 0)
    titleLbl.Position       = UDim2.new(0, titleOffX, 0, 0)
    titleLbl.Text           = title
    titleLbl.TextColor3     = T.Text
    titleLbl.TextSize       = 13
    titleLbl.Font           = Enum.Font.GothamBold
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.TextTruncate   = Enum.TextTruncate.AtEnd
    titleLbl.Parent         = titleRow

    -- Mensagem (opcional)
    if message ~= "" then
        local msgLbl = Instance.new("TextLabel")
        msgLbl.BackgroundTransparency = 1
        msgLbl.Size           = UDim2.new(1, 0, 0, 0)
        msgLbl.AutomaticSize  = Enum.AutomaticSize.Y
        msgLbl.Text           = message
        msgLbl.TextColor3     = T.TextMuted
        msgLbl.TextSize       = 12
        msgLbl.Font           = Enum.Font.Gotham
        msgLbl.TextXAlignment = Enum.TextXAlignment.Left
        msgLbl.TextWrapped    = true
        msgLbl.LayoutOrder    = 2
        msgLbl.Parent         = content
    end

    -- Progress bar track
    local pgTrack = Instance.new("Frame")
    pgTrack.BackgroundColor3 = T.BorderSubtle
    pgTrack.BorderSizePixel  = 0
    pgTrack.Size             = UDim2.new(1, 0, 0, 2)
    pgTrack.LayoutOrder      = 3
    pgTrack.Parent           = content

    local pgFill = Instance.new("Frame")
    pgFill.BackgroundColor3 = accent
    pgFill.BorderSizePixel  = 0
    pgFill.Size             = UDim2.new(1, 0, 1, 0)
    pgFill.Parent           = pgTrack

    -- Sincroniza a altura do outer/inner com o content (depois do layout render)
    local function syncHeight()
        local h = content.AbsoluteSize.Y
        if h > 0 then
            notifOuter.Size = UDim2.new(1, 0, 0, h)
        end
    end
    content:GetPropertyChangedSignal("AbsoluteSize"):Connect(syncHeight)
    task.defer(syncHeight)

    -- Animação de entrada
    notifOuter.Position = UDim2.new(0.08, 0, 0, 0)
    Tween(notifOuter, { Position = UDim2.new(0, 0, 0, 0) }, 0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    Tween(pgFill, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Saída
    task.delay(duration, function()
        Tween(notifOuter, { Position = UDim2.new(0.08, 0, 0, 0) }, 0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        task.wait(0.24)
        notifOuter:Destroy()
    end)

    return notifOuter
end

function NexusUI:CreateWindow(config)
    local cfg        = config or {}
    local keyEnabled = cfg.KeySystem == true
    local keySettings = cfg.KeySettings or {}

    -- Lê configurações salvas ANTES de construir a janela
    local _hs = game:GetService("HttpService")
    local _sf = "NexusUI_Settings.json"
    pcall(function()
        if isfile and isfile(_sf) then
            local ok, data = pcall(function() return _hs:JSONDecode(readfile(_sf)) end)
            if ok and type(data) == "table" then
                -- Sobrescreve o tema passado no código com o tema salvo pelo usuário
                if type(data.theme) == "string" and Themes[data.theme] then
                    cfg.Theme = data.theme
                end
            end
        end
    end)

    -- Se KeySystem estiver ativo, mostra a tela de key antes de tudo
    if keyEnabled then
        local ks         = keySettings
        local ksTitle    = ks.Title    or "Key System"
        local ksSub      = ks.Subtitle or "Digite sua key para continuar"
        local ksNote     = ks.Note     or "Consulte o criador do script para obter a key."
        local ksFile     = ks.FileName or "NexusKey"
        local ksSave     = ks.SaveKey  ~= false
        local ksFromSite = ks.GrabKeyFromSite == true
        local ksKeys     = ks.Key  or {}
        local themeName  = cfg.Theme or "Dark"
        local T          = Themes[themeName] or Themes.Dark

        -- Resolve o KeyLink — usa o valor direto, sem nenhuma conversão
        local ksLink    = nil
        local ksDiscord = nil
        if ks.KeyLink then
            local raw = tostring(ks.KeyLink):match("^%s*(.-)%s*$")
            -- Detecta código Discord APENAS se o usuário explicitamente usar discord.gg/
            local discordCode = raw:match("^discord%.gg/([%w%-]+)")
                             or raw:match("^discord%.com/invite/([%w%-]+)")
            if discordCode then
                ksDiscord = discordCode
                ksLink    = "https://discord.gg/" .. discordCode
            else
                -- Qualquer outro valor: usa direto (URL, link, texto)
                ksLink = raw
            end
        end

        -- Função para abrir invite do Discord via RPC local (abre direto no app)
        local function openDiscordInvite(code)
            local HttpService = game:GetService("HttpService")
            local requestFn = request or http_request or (syn and syn.request) or nil
            if not requestFn then return false end

            local ok = pcall(function()
                requestFn({
                    Url    = "http://127.0.0.1:6463/rpc?v=1",
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json",
                        ["Origin"]       = "https://discord.com",
                    },
                    Body = HttpService:JSONEncode({
                        cmd   = "INVITE_BROWSER",
                        nonce = HttpService:GenerateGUID(false),
                        args  = { code = code },
                    }),
                })
            end)
            return ok
        end

        -- Retorna uma promise-like: bloqueia até key ser validada
        local validated = false

        -- Verifica se já existe key salva
        local savedKey = ""
        if ksSave then
            pcall(function()
                if isfile and isfile(ksFile .. ".txt") then
                    savedKey = readfile(ksFile .. ".txt")
                end
            end)
        end

        -- Função que valida uma key contra a lista (strings ou URLs)
        local function validateKey(input)
            input = input:match("^%s*(.-)%s*$") -- trim
            if input == "" then return false end

            for _, k in ipairs(ksKeys) do
                if ksFromSite then
                    -- Busca conteúdo da URL e compara
                    local ok, content = pcall(function()
                        return game:HttpGet(k)
                    end)
                    if ok and content then
                        local trimmed = content:match("^%s*(.-)%s*$")
                        if trimmed == input then return true end
                    end
                else
                    -- Comparação direta
                    if k == input then return true end
                end
            end
            return false
        end

        -- Tenta validar key salva automaticamente
        if savedKey ~= "" and validateKey(savedKey) then
            validated = true
        end

        if not validated then
            local keyOuter, keyInner = MakeRoundedFrame(ScreenGui, T.WinBg, 8, T.Border, 1)
            keyOuter.Name     = "NexusKeyScreen"
            keyOuter.Size     = UDim2.new(0, 400, 0, ksLink and 282 or 240)
            keyOuter.Position = UDim2.new(0.5, -200, 0.5, ksLink and -141 or -120)
            keyOuter.ZIndex   = 10

            local keyTitleBar = Instance.new("Frame")
            keyTitleBar.BackgroundColor3 = T.TitleBg
            keyTitleBar.Size             = UDim2.new(1, 0, 0, 44)
            keyTitleBar.BorderSizePixel  = 0
            keyTitleBar.ZIndex           = 10
            keyTitleBar.Parent           = keyInner
            do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,8); c.Parent=keyTitleBar end
            do
                local cover=Instance.new("Frame")
                cover.BackgroundColor3=T.TitleBg; cover.Size=UDim2.new(1,0,0,8)
                cover.Position=UDim2.new(0,0,1,-8); cover.BorderSizePixel=0; cover.ZIndex=11
                cover.Parent=keyTitleBar
            end
            do
                local div=Instance.new("Frame")
                div.BackgroundColor3=T.Border; div.Size=UDim2.new(1,0,0,1)
                div.Position=UDim2.new(0,0,1,-1); div.BorderSizePixel=0; div.ZIndex=12
                div.Parent=keyTitleBar
            end

            -- Arrastar a janela de key pela titlebar
