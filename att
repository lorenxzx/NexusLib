    pcall(function()
        if isfile and isfile(settingsFile) then
            local data = HttpService:JSONDecode(readfile(settingsFile))
            if data and data.theme   and Themes[data.theme]   then savedTheme  = data.theme   end
            if data and data.keybind and data.keybind ~= ""   then savedKbName = data.keybind end
        end
    end)

    local themeName = savedTheme
