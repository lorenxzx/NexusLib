                            task.wait(0.05)
                        end
                        Tween(inputOuter, {Position=origPos}, 0.05)
                    end
                end)
            end

            btnHit.MouseButton1Click:Connect(tryValidate)
            keyBox.FocusLost:Connect(function(enter)
