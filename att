        -- ────────────────────────────────────────
        --  PARAGRAPH (bloco copiável + highlight)
        -- ────────────────────────────────────────
        function tab:AddParagraph(cfg)
            cfg = cfg or {}
            local title   = cfg.Title   or ""
            local content = cfg.Content or ""
            local isCode  = cfg.IsCode  ~= false

            local blockBg   = isCode and T.WinBg    or T.ContentBg
            local blockBord = isCode and T.Border    or T.CardBorder

            local outer, inner = MakeRoundedFrame(scroll, T.Card, 6, T.CardBorder, 1)
            outer.Size          = UDim2.new(1, 0, 0, 0)
            outer.AutomaticSize = Enum.AutomaticSize.Y
            inner.AutomaticSize = Enum.AutomaticSize.Y
            AddPadding(inner, 10, 10, 12, 12)

            local lay = Instance.new("UIListLayout")
            lay.SortOrder = Enum.SortOrder.LayoutOrder
            lay.Padding   = UDim.new(0, 6)
            lay.Parent    = inner

            if title ~= "" then
                local tRow = Instance.new("Frame")
                tRow.BackgroundTransparency = 1
                tRow.Size        = UDim2.new(1, 0, 0, 18)
                tRow.LayoutOrder = 1
                tRow.Parent      = inner

                local tLbl = Instance.new("TextLabel")
                tLbl.BackgroundTransparency = 1
                tLbl.Size           = UDim2.new(1, -28, 1, 0)
                tLbl.Text           = title
                tLbl.TextColor3     = T.Text
                tLbl.TextSize       = 12
                tLbl.Font           = Enum.Font.GothamBold
                tLbl.TextXAlignment = Enum.TextXAlignment.Left
                tLbl.Parent         = tRow

                local copyBtn = Instance.new("ImageButton")
                copyBtn.BackgroundTransparency = 1
                copyBtn.Size        = UDim2.new(0, 16, 0, 16)
                copyBtn.Position    = UDim2.new(1, -16, 0.5, -8)
                copyBtn.ImageColor3 = T.TextMuted
                copyBtn.ScaleType   = Enum.ScaleType.Fit
                copyBtn.Parent      = tRow
                applyIcon(copyBtn, "copy")
                copyBtn.MouseEnter:Connect(function() Tween(copyBtn,{ImageColor3=T.AccentText},0.1) end)
                copyBtn.MouseLeave:Connect(function() Tween(copyBtn,{ImageColor3=T.TextMuted},0.1) end)
                copyBtn.MouseButton1Click:Connect(function()
                    pcall(function() setclipboard(content) end)
                    Tween(copyBtn, {ImageColor3=T.Success}, 0.12)
                    Tween(copyBtn, {Size=UDim2.new(0,12,0,12), Position=UDim2.new(1,-14,0.5,-6)}, 0.1)
                    task.delay(0.1, function()
                        Tween(copyBtn, {Size=UDim2.new(0,18,0,18), Position=UDim2.new(1,-18,0.5,-9)}, 0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    end)
                    task.delay(1.5, function()
                        Tween(copyBtn, {ImageColor3=T.TextMuted, Size=UDim2.new(0,16,0,16), Position=UDim2.new(1,-16,0.5,-8)}, 0.2)
                    end)
                    NexusUI:Notify({
                        Title    = "Copiado!",
                        Message  = '"' .. title .. '" copiado para a área de transferência.',
                        Type     = "Success",
                        Duration = 2,
                    })
                end)
            end

            local codeOuter, codeInner = MakeRoundedFrame(inner, blockBg, 4, blockBord, 1)
            codeOuter.Size          = UDim2.new(1, 0, 0, 0)
            codeOuter.AutomaticSize = Enum.AutomaticSize.Y
            codeOuter.LayoutOrder   = 2
            codeInner.AutomaticSize = Enum.AutomaticSize.Y
            AddPadding(codeInner, 8, 8, 10, 10)

            local cLbl = Instance.new("TextLabel")
            cLbl.BackgroundTransparency = 1
            cLbl.Size           = UDim2.new(1, 0, 0, 0)
            cLbl.AutomaticSize  = Enum.AutomaticSize.Y
            cLbl.TextXAlignment = Enum.TextXAlignment.Left
            cLbl.TextWrapped    = true
            cLbl.TextSize       = 11
            cLbl.Font           = isCode and Enum.Font.Code or Enum.Font.Gotham
            cLbl.Parent         = codeInner

            if isCode then
                cLbl.RichText   = true
                cLbl.TextColor3 = T.TextMuted

                local cKw  = "c084fc"  -- keywords: roxo
                local cStr = "86efac"  -- strings:  verde
                local cNum = "fb923c"  -- números:  laranja
                local cFn  = "60a5fa"  -- builtins: azul
                local cCmt = "6b7280"  -- comments: cinza
                local cBool= "f87171"  -- bool/nil: vermelho

                local kwSet = {
                    ["local"]=1,["function"]=1,["end"]=1,["if"]=1,["then"]=1,
                    ["else"]=1,["elseif"]=1,["for"]=1,["while"]=1,["do"]=1,
                    ["return"]=1,["in"]=1,["not"]=1,["and"]=1,["or"]=1,
                    ["repeat"]=1,["until"]=1,["break"]=1,["continue"]=1,
                }
                local fnSet = {
                    ["print"]=1,["warn"]=1,["error"]=1,["pairs"]=1,["ipairs"]=1,
                    ["next"]=1,["tostring"]=1,["tonumber"]=1,["type"]=1,
                    ["math"]=1,["table"]=1,["string"]=1,["task"]=1,
                    ["game"]=1,["workspace"]=1,["script"]=1,["pcall"]=1,
                }

                local function esc(s)
                    return s:gsub("&","&amp;"):gsub("<","&lt;"):gsub(">","&gt;"):gsub('"',"&quot;")
                end

                local function highlight(src)
                    local lines = {}
                    for line in (src.."\n"):gmatch("([^\n]*)\n") do
                        -- Linha de comentário
                        if line:match("^%s*%-%-") then
                            table.insert(lines, '<font color="#'..cCmt..'">'..esc(line)..'</font>')
                        else
                            local res = ""
                            local i = 1
                            while i <= #line do
                                local c = line:sub(i,i)
                                -- Inline comment
                                if line:sub(i,i+1) == "--" then
                                    res = res..'<font color="#'..cCmt..'">'..esc(line:sub(i))..'</font>'
                                    break
                                -- String dupla
                                elseif c == '"' or c == "'" then
                                    local j = i+1
                                    while j <= #line do
                                        if line:sub(j,j) == c and line:sub(j-1,j-1) ~= "\\" then break end
                                        j = j+1
                                    end
                                    local tok = line:sub(i,j)
                                    res = res..'<font color="#'..cStr..'">'..esc(tok)..'</font>'
                                    i = j+1
                                -- Número
                                elseif c:match("%d") then
                                    local tok = line:sub(i):match("^%d+%.?%d*")
                                    res = res..'<font color="#'..cNum..'">'..esc(tok)..'</font>'
                                    i = i+#tok
                                -- Palavra
                                elseif c:match("[%a_]") then
                                    local tok = line:sub(i):match("^[%a_%d]+")
                                    if tok == "true" or tok == "false" or tok == "nil" then
                                        res = res..'<font color="#'..cBool..'">'..esc(tok)..'</font>'
                                    elseif kwSet[tok] then
                                        res = res..'<font color="#'..cKw..'">'..esc(tok)..'</font>'
                                    elseif fnSet[tok] then
                                        res = res..'<font color="#'..cFn..'">'..esc(tok)..'</font>'
                                    else
                                        res = res..esc(tok)
                                    end
                                    i = i+#tok
                                else
                                    res = res..esc(c)
                                    i = i+1
                                end
                            end
                            table.insert(lines, res)
                        end
                    end
                    return table.concat(lines, "\n")
                end

                cLbl.Text = highlight(content)
            else
                cLbl.RichText   = false
                cLbl.Text       = content
                cLbl.TextColor3 = T.TextMuted
            end

            table.insert(self._elements, {label=(title..content):lower(), frame=outer})
            return outer
        end

        -- ────────────────────────────────────────
        --  DROPDOWN (seleção única)
        -- ────────────────────────────────────────
        function tab:AddDropdown(cfg)
            cfg = cfg or {}
            local lbl     = cfg.Label    or "Dropdown"
            local options = cfg.Options  or {}
            local default = cfg.Default  or (options[1] or "")
            local cb      = cfg.Callback or function() end
            local current = default
            local isOpen  = false

            -- Container que cresce quando aberto
            local outer, inner = MakeRoundedFrame(scroll, T.Card, 6, T.CardBorder, 1)
            outer.Size = UDim2.new(1,0,0,38)

            -- Header do dropdown
            local headerLbl = Instance.new("TextLabel")
            headerLbl.BackgroundTransparency = 1
            headerLbl.Size           = UDim2.new(1,-50,0,38)
            headerLbl.Position       = UDim2.new(0,14,0,0)
            headerLbl.Text           = lbl
            headerLbl.TextColor3     = T.Text
            headerLbl.TextSize       = 13
            headerLbl.Font           = Enum.Font.Gotham
            headerLbl.TextXAlignment = Enum.TextXAlignment.Left
            headerLbl.Parent         = inner

            local valueLbl = Instance.new("TextLabel")
            valueLbl.BackgroundTransparency = 1
            valueLbl.Size           = UDim2.new(0,70,0,38)
            valueLbl.Position       = UDim2.new(1,-96,0,0)
            valueLbl.Text           = current
            valueLbl.TextColor3     = T.AccentText
            valueLbl.TextSize       = 11
            valueLbl.Font           = Enum.Font.GothamBold
            valueLbl.TextXAlignment = Enum.TextXAlignment.Right
            valueLbl.TextTruncate   = Enum.TextTruncate.AtEnd
            valueLbl.Parent         = inner

            local arrowImg = Instance.new("ImageLabel")
            arrowImg.BackgroundTransparency = 1
            arrowImg.Size       = UDim2.new(0, 12, 0, 12)
            arrowImg.Position   = UDim2.new(1, -20, 0.5, -6)
            arrowImg.ImageColor3 = T.TextMuted
            arrowImg.ScaleType  = Enum.ScaleType.Fit
            arrowImg.Parent     = inner
            applyIcon(arrowImg, "chevron-down")

            -- Lista de opções (começa oculta)
            local listFrame = Instance.new("Frame")
            listFrame.BackgroundTransparency = 1
            listFrame.Size             = UDim2.new(1,0,0,0)
            listFrame.Position         = UDim2.new(0,0,0,38)
            listFrame.ClipsDescendants = true
            listFrame.BorderSizePixel  = 0
            listFrame.Parent           = inner

            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Parent    = listFrame

            local itemH = 30

            -- Divisor antes da lista
            do
                local div = Instance.new("Frame")
                div.BackgroundColor3 = T.Border
                div.Size             = UDim2.new(1,0,0,1)
                div.BorderSizePixel  = 0
                div.LayoutOrder      = 0
                div.Parent           = listFrame
            end

            for i, opt in ipairs(options) do
                local itemBtn = Instance.new("TextButton")
                itemBtn.BackgroundColor3 = opt == current and T.TabActiveBg or Color3.fromRGB(0,0,0)
                itemBtn.BackgroundTransparency = opt == current and 0 or 1
                itemBtn.Size             = UDim2.new(1,0,0,itemH)
                itemBtn.Text             = ""
                itemBtn.BorderSizePixel  = 0
                itemBtn.LayoutOrder      = i
                itemBtn.Parent           = listFrame

                local itemLbl = Instance.new("TextLabel")
                itemLbl.BackgroundTransparency = 1
                itemLbl.Size           = UDim2.new(1,-24,1,0)
                itemLbl.Position       = UDim2.new(0,14,0,0)
                itemLbl.Text           = opt
                itemLbl.TextColor3     = opt == current and T.Text or T.TextMuted
                itemLbl.TextSize       = 12
                itemLbl.Font           = opt == current and Enum.Font.GothamBold or Enum.Font.Gotham
                itemLbl.TextXAlignment = Enum.TextXAlignment.Left
                itemLbl.Parent         = itemBtn

                itemBtn.MouseEnter:Connect(function()
                    if opt ~= current then Tween(itemBtn,{BackgroundTransparency=0,BackgroundColor3=T.CardHover},0.1) end
                end)
                itemBtn.MouseLeave:Connect(function()
                    if opt ~= current then Tween(itemBtn,{BackgroundTransparency=1},0.1) end
                end)
                itemBtn.MouseButton1Click:Connect(function()
                    for _, ch in ipairs(listFrame:GetChildren()) do
                        if ch:IsA("TextButton") then
                            Tween(ch,{BackgroundTransparency=1},0.1)
                            local cl = ch:FindFirstChildOfClass("TextLabel")
                            if cl then cl.TextColor3=T.TextMuted; cl.Font=Enum.Font.Gotham end
                        end
                    end
                    Tween(itemBtn,{BackgroundColor3=T.TabActiveBg,BackgroundTransparency=0},0.1)
                    itemLbl.TextColor3 = T.Text
                    itemLbl.Font       = Enum.Font.GothamBold
                    current            = opt
                    valueLbl.Text      = opt
                    isOpen = false
                    Tween(arrowImg, {Rotation=0}, 0.18)
                    local totalH = #options * itemH + 1
                    Tween(listFrame, {Size=UDim2.new(1,0,0,0)}, 0.18)
                    Tween(outer, {Size=UDim2.new(1,0,0,38)}, 0.18)
                    cb(opt)
                end)
            end

            -- Hit area do header
            local hit = Instance.new("TextButton")
            hit.BackgroundTransparency = 1
            hit.Size   = UDim2.new(1,0,0,38)
            hit.Text   = ""
            hit.Parent = inner
            hit.MouseEnter:Connect(function() Tween(inner,{BackgroundColor3=T.CardHover},0.1) end)
            hit.MouseLeave:Connect(function() Tween(inner,{BackgroundColor3=T.Card},0.1) end)
            hit.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(arrowImg, {Rotation = isOpen and 180 or 0}, 0.2)
                local totalH = #options * itemH + 1
                if isOpen then
                    Tween(listFrame, {Size=UDim2.new(1,0,0,totalH)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    Tween(outer, {Size=UDim2.new(1,0,0,38+totalH)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                else
                    Tween(listFrame, {Size=UDim2.new(1,0,0,0)}, 0.15)
                    Tween(outer, {Size=UDim2.new(1,0,0,38)}, 0.15)
                end
            end)

            table.insert(self._elements, {label=lbl:lower(), frame=outer})
            local obj = {}
            function obj:Set(v)
                current = v; valueLbl.Text = v; cb(v)
            end
            function obj:Get() return current end
            return obj
        end

        -- ────────────────────────────────────────
        --  MULTI DROPDOWN (seleção múltipla)
        -- ────────────────────────────────────────
        function tab:AddMultiDropdown(cfg)
            cfg = cfg or {}
            local lbl     = cfg.Label    or "Selecionar"
            local options = cfg.Options  or {}
            local default = cfg.Default  or {}
            local cb      = cfg.Callback or function() end
            local isOpen  = false

            -- Estado de cada opção
            local selected = {}
            for _, v in ipairs(default) do selected[v] = true end

            local function getSelectedText()
                local t = {}
                for _, o in ipairs(options) do if selected[o] then table.insert(t, o) end end
                if #t == 0 then return "Nenhum"
                elseif #t == 1 then return t[1]
                else return #t .. " selecionados" end
            end

            local outer, inner = MakeRoundedFrame(scroll, T.Card, 6, T.CardBorder, 1)
            outer.Size = UDim2.new(1,0,0,38)

            local headerLbl = Instance.new("TextLabel")
            headerLbl.BackgroundTransparency = 1
            headerLbl.Size           = UDim2.new(1,-50,0,38)
            headerLbl.Position       = UDim2.new(0,14,0,0)
            headerLbl.Text           = lbl
            headerLbl.TextColor3     = T.Text
            headerLbl.TextSize       = 13
            headerLbl.Font           = Enum.Font.Gotham
            headerLbl.TextXAlignment = Enum.TextXAlignment.Left
            headerLbl.Parent         = inner

            local valueLbl = Instance.new("TextLabel")
            valueLbl.BackgroundTransparency = 1
            valueLbl.Size           = UDim2.new(0,70,0,38)
            valueLbl.Position       = UDim2.new(1,-96,0,0)
            valueLbl.Text           = getSelectedText()
            valueLbl.TextColor3     = T.AccentText
            valueLbl.TextSize       = 11
            valueLbl.Font           = Enum.Font.GothamBold
            valueLbl.TextXAlignment = Enum.TextXAlignment.Right
            valueLbl.TextTruncate   = Enum.TextTruncate.AtEnd
            valueLbl.Parent         = inner

            local arrowImg2 = Instance.new("ImageLabel")
            arrowImg2.BackgroundTransparency = 1
            arrowImg2.Size       = UDim2.new(0, 12, 0, 12)
            arrowImg2.Position   = UDim2.new(1, -20, 0.5, -6)
            arrowImg2.ImageColor3 = T.TextMuted
            arrowImg2.ScaleType  = Enum.ScaleType.Fit
            arrowImg2.Parent     = inner
            applyIcon(arrowImg2, "chevron-down")

            local listFrame = Instance.new("Frame")
            listFrame.BackgroundTransparency = 1
            listFrame.Size             = UDim2.new(1,0,0,0)
            listFrame.Position         = UDim2.new(0,0,0,38)
            listFrame.ClipsDescendants = true
            listFrame.BorderSizePixel  = 0
            listFrame.Parent           = inner

            local listLayout = Instance.new("UIListLayout")
            listLayout.SortOrder = Enum.SortOrder.LayoutOrder
            listLayout.Parent    = listFrame

            local itemH = 30
            do
                local div = Instance.new("Frame")
                div.BackgroundColor3 = T.Border
                div.Size             = UDim2.new(1,0,0,1)
                div.BorderSizePixel  = 0
                div.LayoutOrder      = 0
                div.Parent           = listFrame
            end

            for i, opt in ipairs(options) do
                local isOn = selected[opt] == true

                local itemBtn = Instance.new("TextButton")
                itemBtn.BackgroundColor3       = isOn and T.TabActiveBg or Color3.fromRGB(0,0,0)
                itemBtn.BackgroundTransparency = isOn and 0 or 1
                itemBtn.Size                   = UDim2.new(1,0,0,itemH)
                itemBtn.Text                   = ""
                itemBtn.BorderSizePixel        = 0
                itemBtn.LayoutOrder            = i
                itemBtn.Parent                 = listFrame

                local itemLbl = Instance.new("TextLabel")
                itemLbl.BackgroundTransparency = 1
                itemLbl.Size           = UDim2.new(1,-38,1,0)
                itemLbl.Position       = UDim2.new(0,14,0,0)
                itemLbl.Text           = opt
                itemLbl.TextColor3     = isOn and T.Text or T.TextMuted
                itemLbl.TextSize       = 12
                itemLbl.Font           = isOn and Enum.Font.GothamBold or Enum.Font.Gotham
                itemLbl.TextXAlignment = Enum.TextXAlignment.Left
                itemLbl.Parent         = itemBtn

                -- Checkbox
                local checkOuter, checkInner2 = MakeRoundedFrame(itemBtn, isOn and T.Accent or T.Card, 3, T.CardBorder, 1)
                checkOuter.Size     = UDim2.new(0,14,0,14)
                checkOuter.Position = UDim2.new(1,-22,0.5,-7)
                local checkLbl = Instance.new("TextLabel")
                checkLbl.BackgroundTransparency = 1
                checkLbl.Size       = UDim2.new(1,0,1,0)
                checkLbl.Text       = isOn and "v" or ""
                checkLbl.TextColor3 = Color3.fromRGB(255,255,255)
                checkLbl.TextSize   = 9
                checkLbl.Font       = Enum.Font.GothamBold
                checkLbl.Parent     = checkInner2

                itemBtn.MouseButton1Click:Connect(function()
                    selected[opt] = not selected[opt]
                    local on = selected[opt]
                    Tween(itemBtn, {BackgroundColor3=on and T.TabActiveBg or Color3.fromRGB(0,0,0), BackgroundTransparency=on and 0 or 1}, 0.12)
                    itemLbl.TextColor3 = on and T.Text or T.TextMuted
                    itemLbl.Font       = on and Enum.Font.GothamBold or Enum.Font.Gotham
                    Tween(checkInner2, {BackgroundColor3=on and T.Accent or T.Card}, 0.12)
                    checkLbl.Text      = on and "v" or ""
                    valueLbl.Text      = getSelectedText()
                    -- Monta tabela dos selecionados
                    local t = {}
                    for _, o in ipairs(options) do if selected[o] then table.insert(t, o) end end
                    cb(t)
                end)
            end

            local hit = Instance.new("TextButton")
            hit.BackgroundTransparency = 1
            hit.Size   = UDim2.new(1,0,0,38)
            hit.Text   = ""
            hit.Parent = inner
            hit.MouseEnter:Connect(function() Tween(inner,{BackgroundColor3=T.CardHover},0.1) end)
            hit.MouseLeave:Connect(function() Tween(inner,{BackgroundColor3=T.Card},0.1) end)
            hit.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(arrowImg2, {Rotation = isOpen and 180 or 0}, 0.2)
                local totalH = #options * itemH + 1
                if isOpen then
                    Tween(listFrame, {Size=UDim2.new(1,0,0,totalH)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                    Tween(outer, {Size=UDim2.new(1,0,0,38+totalH)}, 0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
                else
                    Tween(listFrame, {Size=UDim2.new(1,0,0,0)}, 0.15)
                    Tween(outer, {Size=UDim2.new(1,0,0,38)}, 0.15)
                end
            end)

            table.insert(self._elements, {label=lbl:lower(), frame=outer})
            local obj = {}
            function obj:Get()
                local t = {}
                for _, o in ipairs(options) do if selected[o] then table.insert(t,o) end end
                return t
            end
            function obj:Set(list)
                selected = {}
                for _,v in ipairs(list) do selected[v]=true end
                valueLbl.Text = getSelectedText()
                cb(list)
            end
            return obj
        end

        -- ────────────────────────────────────────
        --  KEYBIND
        -- ────────────────────────────────────────
        function tab:AddKeybind(cfg)
            cfg = cfg or {}
            local lbl     = cfg.Label    or "Keybind"
            local default = cfg.Default  or Enum.KeyCode.E
            local cb      = cfg.Callback or function() end
            local current = default
            local listening = false

            -- Converte KeyCode.Name para exibição legível
            local keyNames = {
                Zero="0", One="1", Two="2", Three="3", Four="4",
                Five="5", Six="6", Seven="7", Eight="8", Nine="9",
                LeftShift="L.Shift", RightShift="R.Shift",
                LeftControl="L.Ctrl", RightControl="R.Ctrl",
                LeftAlt="L.Alt", RightAlt="R.Alt",
                Return="Enter", BackSpace="Back",
                CapsLock="Caps", Space="Space",
            }
            local function keyName(kc)
                return keyNames[kc.Name] or kc.Name
            end

            local outer, inner = MakeRoundedFrame(scroll, T.Card, 6, T.CardBorder, 1)
            outer.Size = UDim2.new(1,0,0,38)

            local textLbl = Instance.new("TextLabel")
            textLbl.BackgroundTransparency = 1
            textLbl.Size           = UDim2.new(1,-80,1,0)
            textLbl.Position       = UDim2.new(0,14,0,0)
            textLbl.Text           = lbl
            textLbl.TextColor3     = T.Text
            textLbl.TextSize       = 13
            textLbl.Font           = Enum.Font.Gotham
            textLbl.TextXAlignment = Enum.TextXAlignment.Left
            textLbl.Parent         = inner

            local kbOuter2, kbInner2 = MakeRoundedFrame(inner, T.ContentBg, 4, T.Border, 1)
            kbOuter2.Size     = UDim2.new(0,56,0,22)
            kbOuter2.Position = UDim2.new(1,-64,0.5,-11)

            local kbStroke2 = kbOuter2:FindFirstChildOfClass("UIStroke")

            local keyLbl = Instance.new("TextLabel")
            keyLbl.BackgroundTransparency = 1
            keyLbl.Size       = UDim2.new(1,0,1,0)
            keyLbl.Text       = keyName(current)
            keyLbl.TextColor3 = T.AccentText
            keyLbl.TextSize   = 10
            keyLbl.Font       = Enum.Font.GothamBold
            keyLbl.Parent     = kbInner2

            local hit = Instance.new("TextButton")
            hit.BackgroundTransparency = 1
            hit.Size   = UDim2.new(1,0,1,0)
            hit.Text   = ""
            hit.Parent = inner

            hit.MouseButton1Click:Connect(function()
                listening         = true
                keyLbl.Text       = "..."
                keyLbl.TextColor3 = T.TextMuted
                if kbStroke2 then Tween(kbStroke2,{Color=T.Accent},0.15) end
            end)

            UserInputService.InputBegan:Connect(function(inp, gp)
                if gp or not listening then return end
                if inp.UserInputType == Enum.UserInputType.Keyboard then
                    current           = inp.KeyCode
                    keyLbl.Text       = keyName(inp.KeyCode)
                    keyLbl.TextColor3 = T.AccentText
                    listening         = false
                    if kbStroke2 then Tween(kbStroke2,{Color=T.Border},0.15) end
                    cb(inp.KeyCode)
                end
            end)

            UserInputService.InputBegan:Connect(function(inp, gp)
                if gp or listening then return end
                if inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == current then
                    cb(current)
                end
            end)

            table.insert(self._elements, {label=lbl:lower(), frame=outer})
            local obj = {}
            function obj:Set(kc) current=kc; keyLbl.Text=keyName(kc) end
            function obj:Get() return current end
            return obj
        end

        -- ────────────────────────────────────────
        --  COLOR PICKER
        -- ────────────────────────────────────────
        function tab:AddColorPicker(cfg)
            cfg = cfg or {}
            local lbl     = cfg.Label    or "Cor"
            local default = cfg.Default  or Color3.fromRGB(99, 102, 241)
            local cb      = cfg.Callback or function() end

            local r = math.floor(default.R * 255)
            local g = math.floor(default.G * 255)
            local b = math.floor(default.B * 255)

            local outer, inner = MakeRoundedFrame(scroll, T.Card, 6, T.CardBorder, 1)
            outer.Size = UDim2.new(1,0,0,114)
            AddPadding(inner, 10, 10, 14, 14)

            local topRow = Instance.new("Frame")
            topRow.BackgroundTransparency = 1
            topRow.Size   = UDim2.new(1,0,0,18)
            topRow.Parent = inner

            local lText = Instance.new("TextLabel")
            lText.BackgroundTransparency=1; lText.Size=UDim2.new(1,-28,1,0)
            lText.Text=lbl; lText.TextColor3=T.Text; lText.TextSize=13
            lText.Font=Enum.Font.Gotham; lText.TextXAlignment=Enum.TextXAlignment.Left
            lText.Parent=topRow

            -- Preview da cor
            local preview = Instance.new("Frame")
            preview.BackgroundColor3 = default
            preview.Size             = UDim2.new(0, 20, 0, 20)
            preview.Position         = UDim2.new(1,-20,0.5,-10)
            preview.BorderSizePixel  = 0
            preview.Parent           = topRow
            do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,4); c.Parent=preview end

            local sliderNames = {"R", "G", "B"}
            local sliderValues = {r, g, b}
            local sliderRefs   = {}

            local function updateColor()
                local col = Color3.fromRGB(sliderRefs[1], sliderRefs[2], sliderRefs[3])
                preview.BackgroundColor3 = col
                cb(col)
            end

            -- Cores de cada canal para o fill
            local channelColors = {
                Color3.fromRGB(220, 50,  50 ),   -- R
                Color3.fromRGB(50,  200, 50 ),   -- G
                Color3.fromRGB(50,  100, 220),   -- B
            }

            for idx, name in ipairs(sliderNames) do
                local rowY = 22 + (idx-1)*28
                local chanColor = channelColors[idx]

                local rowLbl = Instance.new("TextLabel")
                rowLbl.BackgroundTransparency = 1
                rowLbl.Size     = UDim2.new(0,12,0,14)
                rowLbl.Position = UDim2.new(0,0,0,rowY+2)
                rowLbl.Text     = name
                rowLbl.TextColor3 = chanColor
                rowLbl.TextSize = 10
                rowLbl.Font     = Enum.Font.GothamBold
                rowLbl.Parent   = inner

                local valLbl2 = Instance.new("TextLabel")
                valLbl2.BackgroundTransparency = 1
                valLbl2.Size     = UDim2.new(0,24,0,14)
                valLbl2.Position = UDim2.new(1,-24,0,rowY+2)
                valLbl2.Text     = tostring(sliderValues[idx])
                valLbl2.TextColor3 = chanColor
                valLbl2.TextSize = 10
                valLbl2.Font     = Enum.Font.GothamBold
                valLbl2.Parent   = inner

                local trackBg2 = Instance.new("Frame")
                trackBg2.BackgroundColor3 = T.BorderSubtle
                trackBg2.Size            = UDim2.new(1,-44,0,4)
                trackBg2.Position        = UDim2.new(0,18,0,rowY+5)
                trackBg2.BorderSizePixel = 0
                trackBg2.Parent          = inner
                do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,2); c.Parent=trackBg2 end

                local fill2 = Instance.new("Frame")
                fill2.BackgroundColor3 = chanColor
                fill2.Size             = UDim2.new(sliderValues[idx]/255,0,1,0)
                fill2.BorderSizePixel  = 0
                fill2.Parent           = trackBg2
                do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,2); c.Parent=fill2 end

                local handle2 = Instance.new("Frame")
                handle2.BackgroundColor3 = T.SliderThumb
                handle2.AnchorPoint      = Vector2.new(0.5,0.5)
                handle2.Size             = UDim2.new(0,11,0,11)
                handle2.Position         = UDim2.new(sliderValues[idx]/255,0,0.5,0)
                handle2.BorderSizePixel  = 0
                handle2.Parent           = trackBg2
                do local c=Instance.new("UICorner"); c.CornerRadius=UDim.new(0,6); c.Parent=handle2 end

                sliderRefs[idx] = sliderValues[idx]

                local dragging2 = false

                local function startDrag2(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then
                        dragging2 = true
                        local tp = trackBg2.AbsolutePosition.X
                        local ts = trackBg2.AbsoluteSize.X
                        local px = i.Position.X
                        local v = math.round(math.clamp((px-tp)/ts,0,1)*255)
                        sliderRefs[idx]  = v
                        fill2.Size       = UDim2.new(v/255,0,1,0)
                        handle2.Position = UDim2.new(v/255,0,0.5,0)
                        valLbl2.Text     = tostring(v)
                        updateColor()
                    end
                end

                handle2.InputBegan:Connect(startDrag2)
                trackBg2.InputBegan:Connect(startDrag2)

                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then
                        dragging2 = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(i)
                    if not dragging2 then return end
                    if i.UserInputType == Enum.UserInputType.MouseMovement
                    or i.UserInputType == Enum.UserInputType.Touch then
                        local tp = trackBg2.AbsolutePosition.X
                        local ts = trackBg2.AbsoluteSize.X
                        local v = math.round(math.clamp((i.Position.X-tp)/ts,0,1)*255)
                        sliderRefs[idx]  = v
                        fill2.Size       = UDim2.new(v/255,0,1,0)
                        handle2.Position = UDim2.new(v/255,0,0.5,0)
                        valLbl2.Text     = tostring(v)
                        updateColor()
                    end
                end)
            end

            table.insert(self._elements, {label=lbl:lower(), frame=outer})
            local obj = {}
            function obj:Set(col)
                sliderRefs[1]=math.floor(col.R*255)
                sliderRefs[2]=math.floor(col.G*255)
                sliderRefs[3]=math.floor(col.B*255)
                preview.BackgroundColor3=col; cb(col)
            end
            function obj:Get()
                return Color3.fromRGB(sliderRefs[1],sliderRefs[2],sliderRefs[3])
            end
            return obj
        end

        return tab
    end -- AddTab

    return Win
end -- CreateWindow

return NexusUI
